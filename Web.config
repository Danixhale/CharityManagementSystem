<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="AdminKey" value="AdminPassword123" />
    <add key="SiteTitle" value="Charity Management System" />
  </appSettings>
  
  <connectionStrings>
    <add name="CharityDBConnection" connectionString="Server=YOUR_SERVER;Database=CharityManagementDB;User Id=sa;Password=YOUR_PASSWORD;" providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
    <authentication mode="Forms">
      <forms loginUrl="~/Frontend/Login.aspx" timeout="30" />
    </authentication>
  </system.web>

  <system.webServer>
    <staticContent>
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
    </staticContent>
  </system.webServer>
</configuration>